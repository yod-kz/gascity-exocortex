{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "city_path",
    "config",
    "warnings",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "ok": {
      "const": true
    },
    "city_path": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "ok",
        "warnings",
        "errors"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
