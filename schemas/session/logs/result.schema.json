{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-gc-jsonl": true,
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "target",
    "transcript_path",
    "tail",
    "entry_count",
    "entries"
  ],
