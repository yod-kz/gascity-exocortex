    "schema_version": {
      "const": "1"
    },
    "ok": {
      "const": true
    },
    "target": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "transcript_path": {
      "type": "string"
    },
    "tail": {
      "type": "integer",
      "minimum": 0
    },
    "entry_count": {
      "type": "integer",
      "minimum": 0
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "uuid": {
            "type": "string"
          },
          "parent_uuid": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "subtype": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "compact_boundary": {
            "type": "boolean"
          },
          "text": {
            "type": "string"
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "type": "string"
                },
                "id": {
                  "type": "string"
                },
                "request_id": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "state": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "action": {
                  "type": "string"
                },
                "metadata": true,
                "name": {
                  "type": "string"
                },
                "input": true,
                "tool_use_id": {
                  "type": "string"
                },
                "content": true,
                "is_error": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "message": true
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
