{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "convoy",
    "progress",
    "children"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "ok": {
      "const": true
    },
    "convoy": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "owned"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "owned": {
          "type": "boolean"
        },
        "fields": {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string"
            },
            "notify": {
              "type": "string"
            },
            "merge": {
              "type": "string"
            },
            "target": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "progress": {
      "type": "object",
      "required": [
        "closed",
        "total"
      ],
      "properties": {
        "closed": {
          "type": "integer"
        },
        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "assignee": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
