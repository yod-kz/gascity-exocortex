{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "count",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "ok": {
      "const": true
    },
    "agent": {
      "type": "string"
    },
    "session": {
      "type": "string"
    },
    "count": {
      "type": "integer"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
